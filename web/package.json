{
  "name": "mcphub-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MCP Hub SPA dashboard (Track G redesign)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
